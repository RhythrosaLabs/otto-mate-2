# Required: Core AI engine
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Additional AI models for sub-agents (Claude handles all by default)
GOOGLE_GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Optional: Web Search (Perplexity API for real-time search)
PERPLEXITY_API_KEY=
# OR use Serper for Google search results
SERPER_API_KEY=
# OR use Tavily
TAVILY_API_KEY=
# OR use Brave Search
BRAVE_SEARCH_API_KEY=

# Optional: Luma Dream Machine (video/image generation)
LUMA_API_KEY=

# Database (uses SQLite by default, stored in ./perplexity-computer.db)
DATABASE_PATH=./perplexity-computer.db

# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here
